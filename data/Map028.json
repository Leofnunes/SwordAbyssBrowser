nselheiro",5,0,2]},{"code":401,"indent":0,"parameters":["Randall: Se eles saíram de lá vivos e com a insignia, então era"]},{"code":401,"indent":0,"parameters":["óbvio que o ogro foi derrotado. Mas você havia me prometido que"]},{"code":401,"indent":0,"parameters":["o ogro seria forte o suficiente para matar os dois. E agora?"]},{"code":401,"indent":0,"parameters":["você tem mais alguma ideia \"brilhante\"?"]},{"code":101,"indent":0,"parameters":["traidor",5,0,2]},{"code":401,"indent":0,"parameters":["Dwayne: Como eu iria imaginar que aqueles dois imbecis seriam"]},{"code":401,"indent":0,"parameters":["capazes de derrotar um ogro daquele tamanho? Sem contar que"]},{"code":401,"indent":0,"parameters":["não era um ogro qualquer. Eles só tiveram sorte, apenas isso. "]},{"code":101,"indent":0,"parameters":["conselheiro",4,0,2]},{"code":401,"indent":0,"parameters":["Randall: Bom, isso pouco importa agora que eles passaram no"]},{"code":401,"indent":0,"parameters":["exame. Logo teremos a oportunidade de acabar com vários de"]},{"code":401,"indent":0,"parameters":["uma só vez. Aliás, como anda o plano? Está tudo preparado?"]},{"code":101,"indent":0,"parameters":["traidor",3,0,2]},{"code":401,"indent":0,"parameters":["Dwayne: Sim, Randall. Está tudo conforme planejado e já fiz"]},{"code":401,"indent":0,"parameters":["todos os preparativos. "]},{"code":101,"indent":0,"parameters":["conselheiro",3,0,2]},{"code":401,"indent":0,"parameters":["Randall: Excelente. Logo conseguiremos o que tanto queremos."]},{"code":401,"indent":0,"parameters":["Agora que você finalizou tudo, poderemos ter um pouco de"]},{"code":401,"indent":0,"parameters":["descanso. Com certeza amanhã será um dia cheio. "]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,29,3,5,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"step